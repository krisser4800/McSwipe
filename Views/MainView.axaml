<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:McSwipe.ViewModels"
             x:Class="McSwipe.Views.MainView">

    <UserControl.DataContext>
        <vm:MainViewModel />
    </UserControl.DataContext>

    <Grid RowDefinitions="*,Auto" Margin="20">
        <Border Grid.Row="0"
                Background="#FAFAFA"
                CornerRadius="20"
                Padding="20"
                BoxShadow="0 0 12 #33000000">
            <StackPanel Spacing="10">
                <TextBlock Text="IMAGE FAILED" Foreground="Red" FontSize="20"/>
                <Border CornerRadius="16" ClipToBounds="True">
                    <Image Source="{Binding Current.Image}"
                           Height="220"
                           Stretch="UniformToFill"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>
    